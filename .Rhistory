install.packages("rmarkdown")
rmarkdown::render("report/EpiReserve_Report.Rmd")
---
title: "EpiReserve: SIR Epidemic Mortality & Insurance Reserve Stress"
---
title: "EpiReserve: SIR Epidemic Mortality & Insurance Reserve Stress"
---
title: "EpiReserve - SIR Epidemic Mortality and Insurance Reserve Stress"
library(deSolve)
library(ggplot2)
library(tidyr)
N <- 1000000
parameters <- c(a = 0.0000003, b = 0.1)
initial_state <- c(S = N-1, I = 1, R = 0)
time <- seq(0, 200, by = 1)
sir_equations <- function(time, state, parameters) {
S <- state["S"]; I <- state["I"]; R <- state["R"]
a <- parameters["a"]; b <- parameters["b"]
list(c(-a*S*I, a*S*I - b*I, b*I))
}
sir_output <- as.data.frame(ode(
y = initial_state, times = time,
func = sir_equations, parms = parameters
))
R0 <- (parameters["a"] * N) / parameters["b"]
sir_long <- pivot_longer(sir_output, cols = c(S,I,R),
names_to = "compartment", values_to = "count")
ggplot(sir_long, aes(x=time, y=count, color=compartment)) +
geom_line(size=1.1) +
scale_color_manual(
values = c(S="steelblue", I="red", R="darkgreen"),
labels = c(S="Susceptible", I="Infected", R="Recovered")
) +
labs(title="SIR Epidemic Model",
subtitle = paste("R0 =", round(R0, 2)),
x="Days", y="Number of people", color="Group") +
theme_minimal()
CFR <- 0.01
sir_output$daily_deaths <- CFR * parameters["b"] * sir_output$I
sir_output$cumulative_deaths <- cumsum(sir_output$daily_deaths)
ggplot(sir_output, aes(x=time, y=daily_deaths)) +
geom_line(color="darkred", size=1.1) +
labs(title="Daily Epidemic Deaths",
subtitle = paste("CFR =", CFR*100, "%  |  R0 =", round(R0,2)),
x="Days", y="Daily deaths") +
theme_minimal()
n_policies      <- 10000
benefit         <- 100000
qx_baseline     <- 0.004
baseline_deaths <- n_policies * qx_baseline
baseline_claims <- baseline_deaths * benefit
epidemic_deaths <- max(sir_output$cumulative_deaths)
extra_claims    <- epidemic_deaths * benefit
total_claims    <- baseline_claims + extra_claims
stress_ratio    <- total_claims / baseline_claims
library(deSolve)
library(ggplot2)
library(tidyr)
N <- 1000000
parameters <- c(a = 0.0000003, b = 0.1)
initial_state <- c(S = N-1, I = 1, R = 0)
time <- seq(0, 200, by = 1)
sir_equations <- function(time, state, parameters) {
S <- state["S"]; I <- state["I"]; R <- state["R"]
a <- parameters["a"]; b <- parameters["b"]
list(c(-a*S*I, a*S*I - b*I, b*I))
}
sir_output <- as.data.frame(ode(
y = initial_state, times = time,
func = sir_equations, parms = parameters
))
R0 <- (parameters["a"] * N) / parameters["b"]
sir_long <- pivot_longer(sir_output, cols = c(S,I,R),
names_to = "compartment", values_to = "count")
ggplot(sir_long, aes(x=time, y=count, color=compartment)) +
geom_line(size=1.1) +
scale_color_manual(
values = c(S="steelblue", I="red", R="darkgreen"),
labels = c(S="Susceptible", I="Infected", R="Recovered")
) +
labs(title="SIR Epidemic Model",
subtitle = paste("R0 =", round(R0, 2)),
x="Days", y="Number of people", color="Group") +
theme_minimal()
CFR <- 0.01
sir_output$daily_deaths <- CFR * parameters["b"] * sir_output$I
sir_output$cumulative_deaths <- cumsum(sir_output$daily_deaths)
ggplot(sir_output, aes(x=time, y=daily_deaths)) +
geom_line(color="darkred", size=1.1) +
labs(title="Daily Epidemic Deaths",
subtitle = paste("CFR =", CFR*100, "%  |  R0 =", round(R0,2)),
x="Days", y="Daily deaths") +
theme_minimal()
n_policies      <- 10000
benefit         <- 100000
qx_baseline     <- 0.004
baseline_deaths <- n_policies * qx_baseline
baseline_claims <- baseline_deaths * benefit
epidemic_deaths <- max(sir_output$cumulative_deaths)
extra_claims    <- epidemic_deaths * benefit
total_claims    <- baseline_claims + extra_claims
stress_ratio    <- total_claims / baseline_claims
file.create("data/.gitkeep")
file.create("tests/.gitkeep")
# save simulation parameters as CSV
params_df <- data.frame(
parameter = c("a", "b", "R0", "CFR", "N", "n_policies", "benefit"),
value     = c(0.0000003, 0.1, 3.0, 0.01, 1000000, 10000, 100000),
description = c(
"infection rate",
"recovery rate",
"basic reproduction number",
"case fatality rate",
"total population",
"number of policies",
"death benefit per policy"
)
)
write.csv(params_df, "data/simulation_parameters.csv", row.names = FALSE)
library(testthat)
library(deSolve)
source("R/sir_model.R")
test_that("population is conserved", {
total <- sir_output$S + sir_output$I + sir_output$R
expect_true(all(abs(total - 1000000) < 1))
})
test_that("R0 is correct", {
expect_equal(round(R0, 0), 3)
})
library(testthat)
library(deSolve)
source("R/sir_model.R")
test_that("population is conserved", {
total <- sir_output$S + sir_output$I + sir_output$R
expect_true(all(abs(total - 1000000) < 1))
})
test_that("R0 is correct", {
expect_equal(unname(round(R0, 0)), 3)
})
